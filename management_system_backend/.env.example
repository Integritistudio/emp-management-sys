PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=management_system
DB_USER=postgres
DB_PASSWORD=your_password

# Optional: cloud hosts often provide a single URL instead
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# CORS — frontend URL(s), comma-separated if multiple
# Required when frontend and backend run on different ports
CLIENT_URL=http://localhost:3000

# Auth
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# First admin bootstrap (created only if admins table is empty)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_strong_password

# PDF
PDF_BRAND_NAME=Integriti

# Rate limiting (per IP, OPTIONS preflight excluded)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
LOGIN_RATE_LIMIT_MAX=20
